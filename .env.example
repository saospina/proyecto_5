# Copy this file to .env and fill in the real values.
# NEVER commit the .env file.

# PostgreSQL connection string.
# Local (docker compose):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/usersdb
# Render (production) — example format:
# DATABASE_URL=postgres://<user>:<password>@<host>.render.com:5432/<database>

# Force SSL for managed providers (Render enables it automatically
# because the host contains "render.com")
# PGSSL=true

PORT=3000
